# PostgreSQL connection for the leaderboard.
# Format: postgres://user:password@host:port/database
DATABASE_URL=postgres://postgres:postgres@localhost:5434/escape_ansem

# Set to "true" to enable SSL (managed services like Neon/Render/Heroku).
# DATABASE_SSL=true

# Max PG connection pool size (default 20).
# PG_POOL_MAX=20

# Token required for POST /api/global/sanity (writing the shared sanity).
# Without a token, writes are rejected (403). Expected header: x-admin-token.
# ADMIN_TOKEN=change-me

# Crypto contract / wallet address shown on the landing page.
# Leave empty -> "TBA" on the site.
# BONK_ADDRESS=

# --- Sanity driven by the on-chain market cap (pump.fun / PumpSwap) ---
# The shared sanity is recomputed every SANITY_POLL_MS from the token market cap:
# sanity = clamp(marketCapUsd / SANITY_MC_TARGET_USD, 0, 1).
# Solana RPC — SERVER-side only (never expose the key to the client). If missing, the
# poller is disabled and sanity stays at its last stored value.
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# Project token mint (starts on the bonding curve; PumpSwap migration handled).
# TOKEN_MINT=YourPumpFunMint...pump
# Ticker shown on the landing (without the "$"). Default: BONK.
# TOKEN_TICKER=BONK
# Market cap (USD) = 100% sanity. Default 1000000.
# SANITY_MC_TARGET_USD=1000000
# Poll interval (ms). Default 10000 (10s).
# SANITY_POLL_MS=10000

# --- Leaderboard anti-cheat: signed run tokens ---
# Enables score-submission verification (signed token issued at run start via
# POST /api/run/start, single-use, elapsed-time consistency). Stable secret required;
# if absent -> verification disabled (backward compatible). Never expose to the client.
# RUN_TOKEN_SECRET=a-long-random-secret-string

# --- Phantom wallet auth (Solana) ---
# HMAC signing secret for wallet sessions. If missing, RUN_TOKEN_SECRET is reused;
# if nothing is set, a random per-boot secret is generated (sessions lost on restart).
# AUTH_SECRET=another-long-random-secret-string
