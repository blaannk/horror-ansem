# Connexion PostgreSQL pour le leaderboard.
# Format : postgres://utilisateur:motdepasse@hote:port/base
DATABASE_URL=postgres://postgres:postgres@localhost:5434/escape_bonk

# Mettre à "true" pour activer SSL (services managés type Neon/Render/Heroku).
# DATABASE_SSL=true

# Taille max du pool de connexions PG (défaut 20).
# PG_POOL_MAX=20

# Jeton requis pour POST /api/global/sanity (écriture de la santé mentale partagée).
# Sans jeton, l'écriture est refusée (403). Header attendu : x-admin-token.
# ADMIN_TOKEN=change-me

# Adresse du contrat / wallet crypto (BONK) affichée sur la page d'accueil.
# Laisser vide → "TBA" côté site.
# BONK_ADDRESS=

# --- Santé mentale pilotée par le market cap on-chain (pump.fun / PumpSwap) ---
# La santé mentale globale est recalculée toutes les SANITY_POLL_MS depuis le market cap
# du token : sanity = clamp(marketCapUsd / SANITY_MC_TARGET_USD, 0, 1).
# RPC Solana — côté SERVEUR uniquement (ne jamais exposer la clé au client). Si absent, le
# poller est désactivé et la santé mentale reste à sa dernière valeur en base.
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=VOTRE_CLE
# Mint du token du projet (démarre sur la bonding curve ; migration PumpSwap gérée).
# TOKEN_MINT=VotreMintPumpFun...pump
# Ticker affiché sur la landing (sans le « $ »). Défaut : BONK.
# TOKEN_TICKER=BONK
# Market cap (USD) = 100 % de santé mentale. Défaut 1 000 000.
# SANITY_MC_TARGET_USD=1000000
# Intervalle de calcul (ms). Défaut 10000 (10 s).
# SANITY_POLL_MS=10000

# --- Anti-triche leaderboard : jetons de run signés ---
# Active la vérification des soumissions de score (jeton signé émis au départ du run via
# POST /api/run/start, usage unique, cohérence chrono ↔ temps réel). Secret stable requis ;
# absent → vérification désactivée (rétro-compatible). Ne jamais exposer côté client.
# RUN_TOKEN_SECRET=une-longue-chaine-aleatoire-secrete

# --- Authentification wallet Phantom (Solana) ---
# Secret de signature des sessions wallet (HMAC). À défaut, RUN_TOKEN_SECRET est réutilisé ;
# à défaut de tout, un secret aléatoire par démarrage est généré (sessions perdues au restart).
# AUTH_SECRET=une-autre-longue-chaine-aleatoire-secrete
